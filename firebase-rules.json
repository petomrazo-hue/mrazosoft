{
  "rules": {
    "tajne": {
      ".read": false,
      ".write": false,

      "$room": {
        ".read": true,
        ".write": true,

        "msgs": {
          ".indexOn": ["ts"],
          "$msg": {
            ".validate": "newData.hasChildren(['iv','ct','ts','cid'])",
            "iv":  { ".validate": "newData.isString() && newData.val().length < 64" },
            "ct":  { ".validate": "newData.isString() && newData.val().length < 4000" },
            "cid": { ".validate": "newData.isString() && newData.val().length < 64" },
            "ts":  { ".validate": "newData.isNumber()" },
            "$other": { ".validate": false }
          }
        },

        "pres": {
          "$cid": {
            ".validate": "newData.hasChild('ts')",
            "ts": { ".validate": "newData.isNumber()" },
            "$other": { ".validate": false }
          }
        },

        "$other": { ".validate": false }
      }
    },

    "analytics": {
      ".read": true,
      "$site": {
        "$day": {
          ".indexOn": ["t"],
          "$evt": {
            ".write": "!data.exists() && newData.exists()",
            ".validate": "newData.hasChildren(['n','t'])",
            "n":    { ".validate": "newData.isString() && newData.val().length < 40" },
            "p":    { ".validate": "newData.isString() && newData.val().length < 256" },
            "r":    { ".validate": "newData.isString() && newData.val().length < 512" },
            "t":    { ".validate": "newData.isNumber()" },
            "form": { ".validate": "newData.isString() && newData.val().length < 80" },
            "$other": { ".validate": false }
          }
        }
      }
    },

    "$other": { ".read": false, ".write": false }
  }
}
